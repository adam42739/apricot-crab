{
  "name": "apricot-crab-infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "apricot-crab-infra": "bin/apricot-crab.ts"
  },
  "scripts": {
    "build:web": "npm --prefix .. run build",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "bootstrap": "cdk bootstrap",
    "deploy:cert": "cdk deploy ApricotCrabCert",
    "deploy:secret": "cdk deploy ApricotCrabSecret",
    "deploy:site": "npm run build:web && cdk deploy ApricotCrabSite",
    "deploy": "npm run build:web && cdk deploy --all",
    "destroy": "cdk destroy --all"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "aws-cdk": "2.1130.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.261.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  }
}
